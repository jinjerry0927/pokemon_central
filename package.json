{
  "name": "pokemon-central",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint src next.config.ts tailwind.config.ts --max-warnings=0",
    "data:roster": "node scripts/sync-champions-roster.mjs --regulation=M-B",
    "data:roster:verify": "node scripts/verify-pokeapi-roster.mjs",
    "data:sync": "node scripts/sync-pokemon.mjs --roster=data/generated/champions-roster-m-b.json --output=data/generated/pokemon-m-b-preview.json",
    "data:sync:sample": "node scripts/sync-pokemon.mjs --roster=data/champions-roster.json --output=data/generated/pokemon-sync-preview.json",
    "data:promote": "node scripts/promote-pokemon-data.mjs",
    "data:moves": "node scripts/sync-moves.mjs",
    "data:moves:pilot": "node scripts/sync-champions-learnset-pilot.mjs",
    "data:moves:pilot:serebii": "node scripts/sync-serebii-learnset-pilot.mjs",
    "data:validate": "node scripts/validate-data.mjs"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0"
  }
}
